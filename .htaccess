<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    # Segurança: Bloquear listagem e arquivos sensíveis
    Options -Indexes
    RewriteRule (^|/)\.(?!well-known) - [F]
    RewriteRule ^(composer\.|package(-lock)?\.json|artisan|Dockerfile|docker-compose|phpunit\.xml|README\.md|CONTRIBUTING\.md|SECURITY\.md|VERSION) - [F]

    # Raiz (/) – redireciona diretamente para /login (evita 404)
    RewriteRule ^/?$ /login [R=302,L]

    # /storage/* – servir de public/storage/ (link simbólico do Laravel)
    RewriteRule ^storage/(.*)$ public/storage/$1 [L]

    # /build/* – servir de public/build/ (assets Vite)
    RewriteRule ^build/(.*)$ public/build/$1 [L]

    # /images/* – servir de public/images/
    RewriteRule ^images/(.*)$ public/images/$1 [L]

    # PWA: garantir arquivos estáticos públicos quando document root não aponta para /public
    RewriteRule ^manifest\.json$ public/manifest.json [L]
    RewriteRule ^painel-sw\.js$ public/painel-sw.js [L]
    RewriteRule ^icons/(.*)$ public/icons/$1 [L]

    # Arquivos/diretórios existentes – não reescrever
    RewriteCond %{REQUEST_FILENAME} -f [OR]
    RewriteCond %{REQUEST_FILENAME} -d
    RewriteRule ^ - [L]

    # Demais requisições – encaminhar para o Laravel
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/index.php [L,QSA]
</IfModule>
